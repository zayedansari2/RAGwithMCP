# Copy this file to .env and fill in your values

# Your OpenRouter API key (https://openrouter.ai/keys)
OPEN_ROUTER_API_KEY=your_openrouter_api_key_here

# LLM model to use via OpenRouter.
# openrouter/auto routes to the best available free model.
# To use a specific model, set its full identifier, e.g.:
#   OPENROUTER_MODEL=openrouter/auto
# The GUI also lets you change the model per-session without restarting.
OPENROUTER_MODEL=openrouter/auto

# Optional: path to the ChromaDB persistent store (defaults to ./chroma_db)
# CHROMA_DB_PATH=./chroma_db
